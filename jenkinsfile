pipeline {
    agent {
            label 'linux'
          }

    stages {

        stage('Checkout Info') {
            steps {
                echo 'Pipeline Started 🚀'

                sh '''
                    echo "Current Workspace:"
                    pwd

                    echo "Workspace Files:"
                    ls -la
                '''
            }
        }
        
        stage('Agent Verification'){
              steps{
                   echo 'Running on jenkins Agent'
 
                sh '''
                   echo "current User:"
                   whoami

                    echo "Hostname:"
                    hostname

                    echo "Workspace:"
                    pwd

                  ''' 

                   }
         }

        stage('Build') {
            steps {
                echo 'Running Build Script 🔨'

                sh '''
                    chmod +x build.sh
                    ./build.sh
                '''
            }
        }

        stage('Archive') {
            steps {
                echo 'Archiving Artifacts 📦'

                archiveArtifacts artifacts: 'output/*'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully ✅'
        }

        failure {
            echo 'Pipeline failed ❌'
        }
    }
}
